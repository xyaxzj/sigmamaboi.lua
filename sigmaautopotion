--  OPENER LUCKY BLOCK
local success, errorMessage = pcall(function()
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local StarterGui = game:GetService("StarterGui")
    
    -- ==========================================
    -- ⚙️ CONFIGS (PENGATURAN TARGET)
    -- ==========================================
    local TargetToolName = "Block Cup"
    
    -- Target: 20:55 WIB (Sama dengan 13:55 UTC)
    local TargetHourUTC = 13
    local TargetMinUTC = 55  
    -- ==========================================
    
    local LastTriggeredDay = -1

    -- Fungsi Notifikasi Super Ringan (Bawaan Roblox)
    local function notify(title, text)
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = title,
                Text = text,
                Duration = 5
            })
        end)
        print("[MOCTA OPENER] " .. title .. " - " .. text)
    end

    notify("System Armed", "Sistem bersiaga. Target: " .. TargetToolName .. " dieksekusi TEPAT pada 13:55 UTC (20:55 WIB).")

    -- MASTER LOOP (HIGH PRECISION TIMER)
    task.spawn(function()
        -- Polling setiap 0.5 detik untuk akurasi tingkat dewa
        while task.wait(0.5) do
            local tUTC = os.date("!*t")
            local h = tUTC.hour
            local m = tUTC.min
            local s = tUTC.sec
            
            -- Pemicu: Tepat di Jam 13, Menit 55 (UTC), rentang 0-5 detik pertama
            if h == TargetHourUTC and m == TargetMinUTC and s <= 5 then
                if LastTriggeredDay ~= tUTC.yday then
                    notify("ACTION!", "Menarik item dari tas dan mengeksekusi...")
                    
                    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    local backpack = LocalPlayer:FindFirstChild("Backpack")
                    
                    if char and humanoid and backpack then
                        -- Mencari Tool di dalam tas atau yang sedang dipegang
                        local tool = backpack:FindFirstChild(TargetToolName) or char:FindFirstChild(TargetToolName)
                        
                        if tool then
                            -- 1. Paksa karakter memegang Tool (Equip)
                            humanoid:EquipTool(tool)
                            
                            -- 2. Jeda super singkat agar server sadar item sudah berpindah ke tangan
                            task.wait(0.2)
                            
                            -- 3. Paksa klik (Activate) dari sistem
                            tool:Activate()
                            
                            notify("Sukses!", TargetToolName .. " berhasil dipakai pada " .. string.format("%02d:%02d:%02d", h, m, s) .. " UTC.")
                        else
                            notify("Gagal!", "Item '" .. TargetToolName .. "' tidak ditemukan di Inventory.")
                        end
                    end
                    
                    LastTriggeredDay = tUTC.yday
                end
            end
        end
    end)

end)

if not success then
    warn("MOCTA OPENER ERROR: " .. tostring(errorMessage))
end
