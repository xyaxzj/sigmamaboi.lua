--- Auto Opener Lucky Block

local success, errorMessage = pcall(function()
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local StarterGui = game:GetService("StarterGui")
    
    -- ==========================================
    -- ⚙️ CONFIGS (PENGATURAN TARGET)
    -- ==========================================
    local TargetToolName = "Block Cup"
    
    -- Target: 20:55 WIB (Sama dengan 13:55 UTC)
    local TargetHourUTC = 14
    local TargetMinUTC = 05  
    -- ==========================================
    
    local LastTriggeredDay = -1

    local function notify(title, text)
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = title,
                Text = text,
                Duration = 5
            })
        end)
        print("[MOCTA OPENER] " .. title .. " - " .. text)
    end

    notify("System Armed", "Mode UNLIMITED BURST aktif. Target: " .. TargetToolName .. " dieksekusi TEPAT pada 13:55 UTC (20:55 WIB).")

    -- MASTER LOOP (HIGH PRECISION TIMER)
    task.spawn(function()
        while task.wait(0.5) do
            local tUTC = os.date("!*t")
            local h = tUTC.hour
            local m = tUTC.min
            local s = tUTC.sec
            
            -- Pemicu: Tepat di Jam 13, Menit 55 (UTC), rentang 0-5 detik pertama
            if h == TargetHourUTC and m == TargetMinUTC and s <= 5 then
                if LastTriggeredDay ~= tUTC.yday then
                    notify("ACTION!", "Memulai pembantaian stok " .. TargetToolName .. "...")
                    
                    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    local backpack = LocalPlayer:FindFirstChild("Backpack")
                    
                    if char and humanoid and backpack then
                        
                        -- Cari barangnya
                        local activeTool = char:FindFirstChild(TargetToolName) or backpack:FindFirstChild(TargetToolName)
                        local clickCount = 0
                        
                        -- [UNLIMITED BURST] Selama barang masih ada, hajar terus!
                        while activeTool do
                            -- Pastikan barang ada di tangan (Equipped)
                            if activeTool.Parent ~= char then
                                humanoid:EquipTool(activeTool)
                                task.wait(0.1)
                            end
                            
                            -- Spam klik
                            activeTool:Activate()
                            clickCount = clickCount + 1
                            task.wait(0.1) -- Jeda aman agar tidak nge-freeze
                            
                            -- Cek apakah barang sudah hancur/terpakai
                            if not activeTool or not activeTool.Parent or activeTool.Parent == workspace then
                                -- Jika hilang, sapu ulang tas untuk mencari sisa stok
                                activeTool = char:FindFirstChild(TargetToolName) or backpack:FindFirstChild(TargetToolName)
                            end
                        end
                        
                        if clickCount > 0 then
                            notify("Habis Terkuras!", "Eksekusi selesai. Total klik: " .. clickCount .. "x.")
                        else
                            notify("Gagal!", "Item '" .. TargetToolName .. "' tidak ditemukan di Inventory.")
                        end
                    end
                    
                    LastTriggeredDay = tUTC.yday
                end
            end
        end
    end)

end)

if not success then
    warn("MOCTA OPENER ERROR: " .. tostring(errorMessage))
end
