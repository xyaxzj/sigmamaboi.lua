-- ==========================================================
-- MOCTA AUTO POTION (HEADLESS + HIGH PRECISION)
-- Build: No UI, 0.5s Polling, Exact Time Execution
-- ==========================================================

local success, errorMessage = pcall(function()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local StarterGui = game:GetService("StarterGui")
    
    local Network = ReplicatedStorage:WaitForChild("Shared", 10):WaitForChild("Packages", 10):WaitForChild("Network", 10)
    
    -- Remote Paths
    local remoteBuy = Network:WaitForChild("rev_VolcanicShop_Buy", 5)
    local remoteUse = Network:WaitForChild("rev_VolcanicShop_UsePotion", 5)
    local remoteOpenShop = Network:FindFirstChild("rev_VolcanicShop_Open") or Network:FindFirstChild("rev_VolcanicShop_Interact")
    
    -- Configs
    local TargetPotion = "Farming Potion"
    local TargetQuantity = 2
    local LastTriggeredHour = -1

    -- Fungsi Notifikasi Bawaan Roblox
    local function notify(title, text)
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = title,
                Text = text,
                Duration = 5
            })
        end)
        print("[MOCTA PRECISION] " .. title .. " - " .. text)
    end

    -- Fungsi Eksekusi
    local function executePotionSequence()
        if remoteOpenShop then pcall(function() remoteOpenShop:FireServer() end); task.wait(0.5) end
        
        for i = 1, TargetQuantity do 
            pcall(function() remoteBuy:FireServer(TargetPotion) end)
            task.wait(0.2) 
        end
        
        task.wait(1.5) 
        
        for i = 1, TargetQuantity do 
            pcall(function() remoteUse:FireServer(TargetPotion) end)
            task.wait(0.2) 
        end
    end

    notify("System Online", "Mocta Precision aktif. Mengeksekusi TEPAT di menit 00 detik 00.")

    -- MASTER LOOP (HIGH PRECISION)
    task.spawn(function()
        -- Mengecek setiap SETENGAH DETIK agar tidak meleset
        while task.wait(0.5) do 
            local timeUTC = os.date("!*t")
            local currentHour = timeUTC.hour
            local currentMin = timeUTC.min
            local currentSec = timeUTC.sec
            
            -- Pemicu: Jam Genap, TEPAT di Menit 0, dan TEPAT di Detik 0 atau 1
            if currentHour % 2 == 0 and currentMin == 0 and currentSec <= 1 then
                if LastTriggeredHour ~= currentHour then
                    notify("Target Locked!", "Menembak Potion " .. TargetQuantity .. "x Tepat Waktu!")
                    
                    executePotionSequence()
                    
                    notify("Success", string.format("Eksekusi sempurna pada %02d:%02d:%02d UTC.", currentHour, currentMin, currentSec))
                    LastTriggeredHour = currentHour
                end
            end
        end
    end)

end)

if not success then
    warn("MOCTA PRECISION ERROR: " .. tostring(errorMessage))
end
