-- ==========================================================
-- MOCTA 2-HOUR FARMING POTION (SIMPLE & ROBUST)
-- Build: Auto Buy -> Auto Use (Khusus Farming Potion)
-- ==========================================================

local success, errorMessage = pcall(function()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    
    -- Sambung ke remote dari log
    local Network = ReplicatedStorage:WaitForChild("Shared", 10):WaitForChild("Packages", 10):WaitForChild("Network", 10)
    local remoteBuy = Network:WaitForChild("rev_VolcanicShop_Buy", 5)
    local remoteUse = Network:WaitForChild("rev_VolcanicShop_UsePotion", 5)

    local AutoFarmingEnabled = false
    local LoopDelay = 7200 -- 2 Jam = 7200 Detik
    local TargetPotion = "Farming Potion"

    local Window = Rayfield:CreateWindow({
        Name = "Auto Potion Logic", 
        LoadingTitle = "Memuat Skrip Simple...", 
        ConfigurationSaving = { Enabled = false }, 
        Theme = "DarkBlue"
    })

    local Tab = Window:CreateTab("🧪 Farming Potion", 4483362458)
    
    local StatusLabel = Tab:CreateParagraph({
        Title = "Status Bot", 
        Content = "Bot sedang tidur."
    })

    local function formatTime(seconds)
        local h = math.floor(seconds / 3600)
        local m = math.floor((seconds % 3600) / 60)
        local s = math.floor(seconds % 60)
        return string.format("%02d Jam %02d Menit %02d Detik", h, m, s)
    end

    Tab:CreateToggle({
        Name = "▶️ Nyalakan Auto Potion (Setiap 2 Jam)",
        CurrentValue = false,
        Callback = function(Value)
            AutoFarmingEnabled = Value
            
            if AutoFarmingEnabled then
                task.spawn(function()
                    while AutoFarmingEnabled do
                        StatusLabel:Set({Title = "Status Bot", Content = "Sedang mengeksekusi Beli & Minum..."})
                        
                        -- 1. Beli Potion
                        pcall(function() remoteBuy:FireServer(TargetPotion) end)
                        
                        -- Jeda 1.5 detik biar server sempat ngasih barangnya ke tas sebelum diminum
                        task.wait(1.5) 
                        
                        -- 2. Minum Potion
                        pcall(function() remoteUse:FireServer(TargetPotion) end)
                        
                        Rayfield:Notify({
                            Title = "Eksekusi Berhasil", 
                            Content = "Telah membeli dan meminum 1x Farming Potion.", 
                            Duration = 3
                        })

                        -- 3. Hitung Mundur 2 Jam
                        local timeLeft = LoopDelay
                        while AutoFarmingEnabled and timeLeft > 0 do
                            StatusLabel:Set({
                                Title = "Status Bot", 
                                Content = "Aktif.\nMenunggu giliran berikutnya dalam: " .. formatTime(timeLeft)
                            })
                            task.wait(1)
                            timeLeft = timeLeft - 1
                        end
                    end
                end)
            else
                StatusLabel:Set({Title = "Status Bot", Content = "Bot dihentikan."})
            end
        end
    })

    Tab:CreateSection("Pintasan Manual")
    Tab:CreateButton({
        Name = "Manual: Beli & Minum 1x Sekarang",
        Callback = function()
            pcall(function() remoteBuy:FireServer(TargetPotion) end)
            task.wait(1.5)
            pcall(function() remoteUse:FireServer(TargetPotion) end)
            Rayfield:Notify({Title = "Sukses", Content = "Eksekusi manual berhasil!", Duration = 3})
        end
    })

end)

if not success then
    warn("MOCTA POTION ERROR: " .. tostring(errorMessage))
    pcall(function() game.StarterGui:SetCore("SendNotification", {Title = "Error", Text = tostring(errorMessage), Duration = 10}) end)
end
