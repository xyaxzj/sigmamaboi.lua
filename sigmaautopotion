-- ==========================================================
-- MOCTA POTION SCHEDULER (EVEN UTC HOURS EDITION)
-- Build: Server Time Sync, Auto Even Hours Logic (00, 02, 04)
-- ==========================================================

local success, errorMessage = pcall(function()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    
    local Network = ReplicatedStorage:WaitForChild("Shared", 10):WaitForChild("Packages", 10):WaitForChild("Network", 10)
    local remoteBuy = Network:WaitForChild("rev_VolcanicShop_Buy", 5)
    local remoteUse = Network:WaitForChild("rev_VolcanicShop_UsePotion", 5)

    local TargetPotion = "Farming Potion"
    local SchedulerEnabled = false
    local LastTriggeredHour = -1 -- Menyimpan jam terakhir agar tidak dobel eksekusi

    local Window = Rayfield:CreateWindow({
        Name = "Mocta Auto Potion", 
        LoadingTitle = "Memuat Jadwal Genap UTC...", 
        ConfigurationSaving = { Enabled = false }, 
        Theme = "DarkBlue"
    })

    local Tab = Window:CreateTab("⏰ Jadwal Genap", 4483362458)

    local ClockLabel = Tab:CreateParagraph({
        Title = "🕒 Waktu Sinkronisasi", 
        Content = "Memuat jam server..."
    })

    -- Update Jam Real-Time di UI
    task.spawn(function()
        while task.wait(1) do
            local timeLocal = os.date("*t") -- Jam HP
            local timeUTC = os.date("!*t")  -- Jam Server (UTC)
            
            ClockLabel:Set({
                Title = "🕒 Waktu Sinkronisasi", 
                Content = string.format("Jam Lokal HP: %02d:%02d:%02d\nJam Global (UTC): %02d:%02d:%02d\n\n📌 Script otomatis mengeksekusi setiap JAM GENAP UTC.", 
                timeLocal.hour, timeLocal.min, timeLocal.sec, 
                timeUTC.hour, timeUTC.min, timeUTC.sec)
            })
        end
    end)

    Tab:CreateSection("Mode Otomatis")

    local StatusLabel = Tab:CreateParagraph({
        Title = "Status Bot", 
        Content = "Bot sedang dimatikan."
    })

    Tab:CreateToggle({
        Name = "▶️ Nyalakan Auto Potion (Jam Genap)",
        CurrentValue = false,
        Callback = function(Value)
            SchedulerEnabled = Value
            
            if SchedulerEnabled then
                task.spawn(function()
                    while SchedulerEnabled do
                        local timeUTC = os.date("!*t")
                        local currentHour = timeUTC.hour
                        local currentMin = timeUTC.min
                        
                        -- LOGIKA INTI: CEK APAKAH JAM SAAT INI ADALAH JAM GENAP
                        if currentHour % 2 == 0 and currentMin >= 0 and currentMin <= 2 then
                            
                            -- Pastikan di jam genap yang sama tidak dieksekusi berkali-kali
                            if LastTriggeredHour ~= currentHour then
                                StatusLabel:Set({Title = "Status Bot", Content = "🔔 Waktunya Event Genap! Mengeksekusi..."})
                                
                                pcall(function() remoteBuy:FireServer(TargetPotion) end)
                                task.wait(1.5)
                                pcall(function() remoteUse:FireServer(TargetPotion) end)
                                
                                Rayfield:Notify({
                                    Title = "Eksekusi Terjadwal", 
                                    Content = string.format("Potion diminum otomatis pada %02d:%02d UTC!", currentHour, currentMin), 
                                    Duration = 4
                                })

                                LastTriggeredHour = currentHour
                            end
                        else
                            StatusLabel:Set({Title = "Status Bot", Content = "Siaga. Menunggu jam genap UTC berikutnya..."})
                        end
                        
                        task.wait(1)
                    end
                end)
            else
                StatusLabel:Set({Title = "Status Bot", Content = "Bot dimatikan."})
            end
        end
    })

    Tab:CreateSection("Pintasan Manual")
    Tab:CreateButton({
        Name = "Manual: Beli & Minum 1x Sekarang",
        Callback = function()
            pcall(function() remoteBuy:FireServer(TargetPotion) end)
            task.wait(1.5)
            pcall(function() remoteUse:FireServer(TargetPotion) end)
            Rayfield:Notify({Title = "Sukses", Content = "Eksekusi manual berhasil!", Duration = 3})
        end
    })

end)

if not success then
    warn("MOCTA POTION ERROR: " .. tostring(errorMessage))
    pcall(function() game.StarterGui:SetCore("SendNotification", {Title = "Error", Text = tostring(errorMessage), Duration = 10}) end)
end
